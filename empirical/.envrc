# uv-managed environment for the empirical track.
# direnv auto-syncs deps and activates the venv on `cd empirical/`.
if ! has uv; then
  echo "uv not found (https://docs.astral.sh/uv/); skipping env setup" >&2
  return 0
fi

watch_file pyproject.toml uv.lock
uv sync --quiet
source .venv/bin/activate
